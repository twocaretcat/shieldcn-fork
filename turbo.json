{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL_OIDC_TOKEN",
    "PERSONAL_SPONSOR_TOKEN",
    "GITHUB_TOKEN",
    "SPONSORS_GITHUB_TOKEN",
    "GITHUB_*",
    "TWITCH_*",
    "YOUTUBE_API_KEY",
    "X_BEARER_TOKEN",
    "SKILLS_SH_API_KEY",
    "TOKEN_ENCRYPTION_KEY",
    "SHIELDCN_*",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "POSTGRES_*",
    "PG*",
    "NEON_PROJECT_ID",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "OPENPANEL_*",
    "BETTER_AUTH_*",
    "ADMIN_*",
    "CONTEXT_DEV_API_KEY",
    "SENTRY_*",
    "NEXT_PUBLIC_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
