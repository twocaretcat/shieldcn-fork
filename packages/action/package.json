{
  "name": "@shieldcn/action",
  "version": "1.0.0",
  "private": true,
  "description": "shieldcn starchart — a GitHub Action that renders a shadcn-styled star-history chart for your repo",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shieldcn/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26",
    "esbuild": "^0.25.0",
    "typescript": "^6"
  }
}
